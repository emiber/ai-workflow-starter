# Example environment variables.
#
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored and must NEVER be committed. Only this example file,
# with placeholder values, belongs in version control. See workflow/principles.md.
#
# /init-project replaces the placeholders below with the variables your chosen
# stack actually needs. Until then this is just a format example.

# EXAMPLE_API_KEY=your-api-key-here
# DATABASE_URL=postgres://user:password@localhost:5432/dbname
